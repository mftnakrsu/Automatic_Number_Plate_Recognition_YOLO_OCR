# Copy to .env and edit. NEVER commit .env.

# --- App ---
ANPR_APP_NAME=anpr
ANPR_LOG_LEVEL=INFO
ANPR_LOG_JSON=false

# --- Pipeline ---
# Run detection every Nth frame; track in between
ANPR_DETECT_EVERY_N_FRAMES=3
# Plate width threshold (px) below which super-resolution kicks in (set 0 to disable)
ANPR_SR_MIN_PLATE_WIDTH=80
# Min frames a track must persist before emitting a confirmed read
ANPR_MIN_TRACK_DWELL=5
# Confidence threshold for OCR fallback (PaddleOCR triggered below this)
ANPR_OCR_FALLBACK_THRESHOLD=0.85

# --- Storage ---
# SQLite path; switch to postgres+asyncpg://... for prod
ANPR_DATABASE_URL=sqlite+aiosqlite:///data/anpr.db
# Plate hashing pepper — REQUIRED, generate with: python -c "import secrets; print(secrets.token_hex(32))"
ANPR_PLATE_HMAC_PEPPER=
# Detection retention in hours; rows older than this are purged by background task
ANPR_RETENTION_HOURS=720

# --- API ---
ANPR_API_HOST=0.0.0.0
ANPR_API_PORT=8000
ANPR_MAX_UPLOAD_MB=10
# CORS origins, comma-separated. * is permissive — restrict in prod.
ANPR_CORS_ORIGINS=*

# --- Observability (optional) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=anpr
